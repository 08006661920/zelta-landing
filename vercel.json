{
  "rewrites": [
    { "source": "/privacidad", "destination": "/privacidad.html" },
    { "source": "/terminos", "destination": "/terminos.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.zelta-digital.com" }],
      "destination": "https://zelta-digital.com/:path*",
      "permanent": true
    }
  ]
}
